---
import Container from "@components/container.astro";
import Layout from "@layouts/Layout.astro";
---

<Layout title="BuzzCup — Terms of Service">
  <Container>
    <div class="prose prose-slate max-w-2xl mx-auto my-16">
      <h1>Terms of Service</h1>
      <p class="text-slate-500 text-sm">Last updated: May 2026</p>

      <h2>SMS Messaging</h2>
      <p>
        BuzzCup operates an SMS notification service for participants of the BuzzCup golf tournament.
      </p>

      <h3>Who Can Opt In</h3>
      <p>Only registered participants of the BuzzCup golf tournament may opt in to SMS messages.</p>

      <h3>How to Opt In</h3>
      <p>Text <strong>START</strong> to <strong>(601) 843-2899</strong>.</p>

      <h3>How to Opt Out</h3>
      <p>Text <strong>STOP</strong> to <strong>(601) 843-2899</strong> at any time. You will receive one final confirmation message and no further messages will be sent.</p>

      <h3>Help</h3>
      <p>Text <strong>HELP</strong> to <strong>(601) 843-2899</strong> or email <a href="mailto:help@buzzcup.golf">help@buzzcup.golf</a>.</p>

      <h3>Message Frequency</h3>
      <p>Message frequency varies. Messages are sent only during the live BuzzCup event.</p>

      <h3>Rates</h3>
      <p>Message and data rates may apply.</p>

      <h3>Carriers</h3>
      <p>Carriers are not liable for delayed or undelivered messages.</p>

      <h2>Privacy</h2>
      <p>See our <a href="/privacy">Privacy Policy</a>.</p>
    </div>
  </Container>
</Layout>
