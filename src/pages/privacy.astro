---
import Container from "@components/container.astro";
import Layout from "@layouts/Layout.astro";
---

<Layout title="BuzzCup — Privacy Policy">
  <Container>
    <div class="prose prose-slate max-w-2xl mx-auto my-16">
      <h1>Privacy Policy</h1>
      <p class="text-slate-500 text-sm">Last updated: May 2026</p>

      <h2>Information We Collect</h2>
      <p>We collect only your phone number when you opt in to BuzzCup SMS messages.</p>

      <h2>How We Use It</h2>
      <p>Your phone number is used solely to send BuzzCup event messages via SMS. It is never sold, rented, or shared with third parties for marketing purposes.</p>

      <h2>SMS Data</h2>
      <p>
        No mobile information will be shared with third parties or affiliates for marketing or promotional purposes.
        All opt-in data and consent information is kept confidential.
      </p>

      <h2>Opt Out</h2>
      <p>Text <strong>STOP</strong> to <strong>(601) 843-2899</strong> to be removed from all future messages.</p>

      <h2>Contact</h2>
      <p>Questions? Email <a href="mailto:help@buzzcup.golf">help@buzzcup.golf</a>.</p>
    </div>
  </Container>
</Layout>
