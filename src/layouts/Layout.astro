---
// @ts-ignore
import { ViewTransitions } from "astro:transitions";
// @ts-ignore
import { Image } from "astro:assets";
// @ts-ignore
import heroImage from "../assets/bc-logo.png";
// @ts-ignore
import { SEO } from "astro-seo";
import Footer from "@components/footer.astro";
import { eventConfig } from "@data/event-config";

import "@fontsource-variable/inter/index.css";
import Container from "@components/container.astro";

const eventStartISO = eventConfig.eventStart.toISOString();
const eventEndISO = eventConfig.eventEnd.toISOString();

// Define your navigation links
const navLinks = [
  { text: "Home", href: "/" },
];

const pastEvents = [
  { text: "BC 2025", href: "/2025" },
  { text: "BC 2024", href: "/2024" },
  { text: "BC 2023", href: "/2023" },
];

export interface Props {
  title?: string;
  footerMargin?: boolean;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const resolvedImageWithDomain = new URL(
  "/opengraph.jpg",
  Astro.site,
).toString();

const { title, footerMargin = true } = Astro.props;

const makeTitle = title
  ? title
  : "BuzzCup 2024 - The Best Event of the Year!";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={makeTitle}
      description="BuzzCup 2025 is the best event of the year. Don't miss out on the fun!"
      canonical={canonicalURL}
      twitter={{
        creator: "@benlower",
        site: "@benlower",
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: `BuzzCup 2025`,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: "BuzzCup 2025 Screenshot",
        },
      }}
    />
    <style is:global>
      /* Improve Page speed */
      /* https://css-tricks.com/almanac/properties/c/content-visibility/ */
      img {
        content-visibility: auto;
      }
    </style>
    <ViewTransitions />
  </head>
  <body>
    <!-- Navigation Bar -->
    <header class="bg-white shadow-sm sticky top-0 z-50">
      <Container>
        <nav class="flex items-center justify-between py-2">
          <!-- Logo Section -->
          <div class="flex items-center">
            <a href="/" class="flex items-center">
              <Image
                src={heroImage}
                alt="Buzzcup 2024"
                width="80"
                loading="eager"
                fetchpriority="high"
                class="h-auto"
              />
            </a>
            <div class="ml-5">
              <div class="text-lg font-bold">
                BuzzCup™
              </div>
              <p class="text-slate-600">
                Links, drinks, high jinks.
              </p>
              <p
                class="text-sm text-slate-600">
                Probably the best golf tourney you can play.
              </p>
            </div>
          </div>

          <!-- Desktop Navigation Menu -->
          <div class="hidden md:flex items-center space-x-8">
            {navLinks.map(link => (
              <a
                href={link.href}
                class="text-gray-700 hover:text-emerald-600 transition-colors font-medium"
              >
                {link.text}
              </a>
            ))}
            <a
              id="nav-messages"
              href="/messages"
              class="hidden text-indigo-600 hover:text-indigo-800 transition-colors font-medium"
            >
              Messages
            </a>
            <!-- Past Events Dropdown -->
            <div class="relative group">
              <button class="flex items-center gap-1 text-gray-700 hover:text-emerald-600 transition-colors font-medium">
                Past Events
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="absolute right-0 mt-2 w-36 bg-white border border-gray-100 rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150">
                {pastEvents.map(link => (
                  <a
                    href={link.href}
                    class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-emerald-600 first:rounded-t-lg last:rounded-b-lg transition-colors"
                  >
                    {link.text}
                  </a>
                ))}
              </div>
            </div>
          </div>

          <!-- Mobile Menu Button -->
          <div class="md:hidden">
            <button 
              id="mobile-menu-toggle" 
              class="text-gray-700 hover:text-emerald-600 focus:outline-none"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
              </svg>
            </button>
          </div>
        </nav>
      </Container>

      <!-- Mobile Navigation Menu (Hidden by default) -->
      <div id="mobile-menu" class="md:hidden hidden bg-white shadow-md">
        <Container>
          <div class="flex flex-col py-4 space-y-4">
            {navLinks.map(link => (
              <a
                href={link.href}
                class="block text-gray-700 hover:text-emerald-600 transition-colors font-medium px-2"
              >
                {link.text}
              </a>
            ))}
            <a
              id="nav-messages-mobile"
              href="/messages"
              class="hidden block text-indigo-600 hover:text-indigo-800 transition-colors font-medium px-2"
            >
              Messages
            </a>
            <!-- Past Events expandable section -->
            <div>
              <button
                id="mobile-past-events-toggle"
                class="flex items-center gap-1 w-full text-left text-gray-700 hover:text-emerald-600 transition-colors font-medium px-2"
              >
                Past Events
                <svg id="mobile-past-events-chevron" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div id="mobile-past-events" class="hidden flex-col pl-4 mt-2 space-y-3">
                {pastEvents.map(link => (
                  <a
                    href={link.href}
                    class="block text-gray-600 hover:text-emerald-600 transition-colors text-sm px-2"
                  >
                    {link.text}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </Container>
      </div>
    </header>
    <slot />
    <Footer margin={footerMargin} />
    <script define:vars={{ eventStartISO, eventEndISO }}>
      function setupNav() {

        // Mobile menu toggle
        const menuToggle = document.getElementById('mobile-menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');
        menuToggle?.addEventListener('click', () => {
          mobileMenu?.classList.toggle('hidden');
        });

        // Past Events sub-menu toggle (mobile)
        const pastEventsToggle = document.getElementById('mobile-past-events-toggle');
        const pastEventsMenu = document.getElementById('mobile-past-events');
        const pastEventsChevron = document.getElementById('mobile-past-events-chevron');
        pastEventsToggle?.addEventListener('click', () => {
          pastEventsMenu?.classList.toggle('hidden');
          pastEventsMenu?.classList.toggle('flex');
          pastEventsChevron?.classList.toggle('rotate-180');
        });
      }

      document.addEventListener('astro:page-load', setupNav);
    </script>
  </body>
</html>
